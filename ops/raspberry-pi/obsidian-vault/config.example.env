# Copy to config.env (gitignored) and adjust paths if needed.

# Live vault on OneDrive (Windows)
VAULT_PATH=C:\Users\Ben\OneDrive\Obsidian\hej

# Separate git metadata — never inside the vault folder
GIT_DIR=%USERPROFILE%\.obsidian-vault-backup\vault.git

# GitHub backup remote (same repo as Pi nightly backup)
GIT_REMOTE=git@github.com:Canopyflick/obsidian-vault-backup.git

# Diary folder relative to vault root
DIARY_FOLDER=Diary
