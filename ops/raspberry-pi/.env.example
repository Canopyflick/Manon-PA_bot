# Copy to .env in this directory. Never commit .env (gitignored via *.env).

# n8n REST API — Settings → API in n8n UI
N8N_API_KEY=your-n8n-api-key-here

# Telegram bot @Nathan_PA_bot — for REST API credential creation
NATHAN_TELEGRAM_BOT_API_KEY=your-telegram-bot-token-here

# Telegram bot @Manon_PA_bot — outbound notifications (sub-workflow Send Message via Manon)
MANON_TELEGRAM_BOT_API_KEY=your-telegram-bot-token-here

# Telegram bot @Obi_obsidianPA_bot — for REST API credential creation / local dev
OBI_TELEGRAM_BOT_API_KEY=your-telegram-bot-token-here

# OpenAI key for Obi voice memo transcription (gpt-4o-mini-transcribe)
OPENAI_OBI_API_KEY=

# OpenRouter key for Obi LLM (separate from Manon's OPENROUTER_API_KEY)
OPENROUTER_OBI_API_KEY=

# Default Telegram chat IDs for test sends (optional)
TELEGRAM_USER_ID_BEN=
TELEGRAM_USER_ID_MATHIJS=

# Google Calendar OAuth (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# Written by scripts/google-oauth-auth.ps1 after consent — backup for re-auth
GOOGLE_OAUTH_REFRESH_TOKEN=
# n8n credential ID for Google Calendar (see docs/google-calendar-oauth.md)
GOOGLE_CALENDAR_CREDENTIAL_ID=Sc6NYYy2HJCpDM78
