# Copy to .env in this directory. Never commit .env (gitignored via *.env).

# n8n REST API — Settings → API in n8n UI
N8N_API_KEY=your-n8n-api-key-here

# Telegram bot @Nathan_PA_bot — for REST API credential creation
NATHAN_TELEGRAM_BOT_API_KEY=your-telegram-bot-token-here

# Google Calendar OAuth (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# Optional after one-time OAuth consent — enables API credential creation without UI
GOOGLE_OAUTH_REFRESH_TOKEN=
